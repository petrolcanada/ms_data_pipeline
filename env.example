# =============================================================================
# Morningstar Data Pipeline — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your passwords/secrets.
# .env is git-ignored; env.example is committed as a reference.
# =============================================================================

# -----------------------------------------------------------------------------
# Snowflake Connection (VPN Side)
# -----------------------------------------------------------------------------
SNOWFLAKE_USER=PETER.LI@CI.COM
SNOWFLAKE_ACCOUNT=CIX-CIX
SNOWFLAKE_WAREHOUSE=CIGAM_PRD_ANALYTICSSPECIALIST_DNA_WH
SNOWFLAKE_DATABASE=CIGAM_PRD_RL
SNOWFLAKE_SCHEMA=MORNINGSTAR_MAIN
SNOWFLAKE_ROLE=CIGAM_PRD_SNOWFLAKE_ANALYTICSSPECIALIST_DNA_FR

# Authentication: sso | password | key_pair
SNOWFLAKE_AUTH_METHOD=sso

# For password auth (if not using SSO):
# SNOWFLAKE_PASSWORD=

# For key pair auth:
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/private_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Optional region (usually not needed with orgname-accountname format):
# SNOWFLAKE_REGION=

# -----------------------------------------------------------------------------
# PostgreSQL Connection (External Side)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=50211
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your_postgres_password>

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Static encryption password for all exported data and metadata files.
# Must be the SAME on both VPN and PSQL sides.
ENCRYPTION_PASSWORD=<your_encryption_password>
KEY_DERIVATION_ITERATIONS=100000

# Obfuscate file and folder names (default: true)
OBFUSCATE_NAMES=true

# API key (for future API features)
API_SECRET_KEY=<your_api_secret_key>
API_HOST=0.0.0.0
API_PORT=8000

# -----------------------------------------------------------------------------
# Data Export / Import Paths
# -----------------------------------------------------------------------------
# VPN side: where encrypted Parquet chunks are written
EXPORT_BASE_DIR=C:\Users\peli\local_repo\ms_dataset

# PSQL side: where encrypted Parquet chunks are read from
IMPORT_BASE_DIR=C:\Users\lzhyx\local_scripts\ms_dataset_init

# Watermarks, import checkpoints, run manifests
STATE_DIR=state

# Rows per chunk (adjust based on table size)
CHUNK_SIZE=100000

# -----------------------------------------------------------------------------
# Compression Optimization
# -----------------------------------------------------------------------------
# Parquet compression codec: zstd | snappy | gzip | brotli
COMPRESSION_TYPE=zstd

# zstd level: 1 (fast) to 22 (max compression). 9 is a good balance.
# 15 for maximum compression if export speed is not a concern.
COMPRESSION_LEVEL=15

# Pre-sort data by merge_keys + watermark_column before writing Parquet.
# Clusters similar values together for 20-40% better compression.
SORT_BEFORE_COMPRESS=true

# Auto-detect low-cardinality columns and apply dictionary encoding.
# Especially effective for string columns like currency, category, status.
USE_DICTIONARY_ENCODING=true

# -----------------------------------------------------------------------------
# Git Delivery
# -----------------------------------------------------------------------------
# Repo mode: single | repo
#   single — no Git repos, just flat export folders
#   repo   — disposable dataset repo (reset each run, no history)
REPO_MODE=repo

# Local path for the dataset repo (created automatically, nuked each run)
DATASET_REPO_DIR=repos/dataset

# Remote Git URL for push/pull (GitHub, GitLab, Gitea, etc.)
# Leave empty if using bundles or manual transfer instead.
#   VPN side:  export -> reset repo -> commit -> force-push
#   PSQL side: shallow clone (fresh each pull, no history needed)
DATASET_REPO_URL=https://github.com/petrolcanada/ms_dataset_init.git

# Where git bundle files are written (for air-gapped transfer)
BUNDLE_OUTPUT_DIR=bundles

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# Optional: Redis URL (for Celery background tasks, if used)
# REDIS_URL=redis://localhost:6379/0
